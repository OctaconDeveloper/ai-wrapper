# =============================================================================
# Multi-Model AI Platform — Environment Variables
# =============================================================================

# Server config
API_HOST=0.0.0.0
API_PORT=45701
COMFYUI_PORT=8188

# Model paths (inside container)
MODELS_DIR=/workspace/models
COMFYUI_DIR=/workspace/ComfyUI

# SDXL / SD 1.5 Config
SDXL_CHECKPOINT=DreamShaper_8.safetensors

# Llama 3.2 3B Config (Uncensored)
MIXTRAL_MODEL_PATH=/workspace/models/llm/Llama-3.2-3B-Instruct-abliterated.Q4_K_M.gguf
MIXTRAL_CONTEXT_LENGTH=32768
# Set to -1 for all-GPU offloading (NVIDIA only), or 0 for CPU-only (Mac/Linux CPU)
MIXTRAL_GPU_LAYERS=0
SKIP_VIDEO=true

# Wan 2.1 Config (local paths — downloaded via wget)
WAN_T2V_MODEL=/workspace/models/video/wan2.1-t2v-1.3b
WAN_I2V_MODEL=/workspace/models/video/wan2.1-i2v-14b

# XTTS Config
XTTS_MODEL=tts_models/multilingual/multi-dataset/xtts_v2
COQUI_TOS_AGREED=1

# GPU Memory Management
MAX_LOADED_MODELS=3
ENABLE_MODEL_OFFLOAD=true

# Auto-Shutdown (saves money on vast.ai)
IDLE_SHUTDOWN_ENABLED=true
IDLE_SHUTDOWN_MINUTES=30
VASTAI_API_KEY=
VASTAI_INSTANCE_ID=

# Security
# Configured as a JSON-encoded list of strings
API_TOKENS=["185ba88fbe26b6d75efc33c919a31fb0a1f229b67e9c0fed", "f6f2dc9446390ec1de160cc3bbe0f171e9fab105ef0f626a", "3a81ff1e95d88cc243c9ebfad2c7e7fe84d3a7e904a40327", "cf0c4016bf5f23fb3a6fd4f252ac5322356e1fdc07b65b8a"]
