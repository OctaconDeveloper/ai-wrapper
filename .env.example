# =============================================================================
# Multi-Model AI Platform — Environment Variables
# =============================================================================

# Server config
API_HOST=0.0.0.0
API_PORT=8000
COMFYUI_PORT=8188

# Model paths (inside container)
MODELS_DIR=/workspace/models
COMFYUI_DIR=/workspace/ComfyUI

# SDXL Config
SDXL_CHECKPOINT=sd_xl_base_1.0.safetensors

# Mixtral Config
MIXTRAL_MODEL_PATH=/workspace/models/llm/dolphin-2.7-mixtral-8x7b.Q4_K_M.gguf
MIXTRAL_CONTEXT_LENGTH=32768
MIXTRAL_GPU_LAYERS=-1

# Wan 2.1 Config (local paths — downloaded via wget)
WAN_T2V_MODEL=/workspace/models/video/wan2.1-t2v-1.3b
WAN_I2V_MODEL=/workspace/models/video/wan2.1-i2v-14b

# XTTS Config
XTTS_MODEL=tts_models/multilingual/multi-dataset/xtts_v2

# GPU Memory Management
MAX_LOADED_MODELS=3
ENABLE_MODEL_OFFLOAD=true
